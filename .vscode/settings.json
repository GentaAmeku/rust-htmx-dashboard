{
  // 保存時の自動フォーマットを有効化
  "editor.formatOnSave": true,

  // Rustファイル(.rs)のデフォルトフォーマッターをrust-analyzerに指定
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },

  // 保存時のチェックを、デフォルトの 'cargo check' から、より強力なリンターである 'clippy' に変更
  "rust-analyzer.check.command": "clippy",

  // Askamaのテンプレート(.html)でTailwindの補完を効かせるための設定
  "files.associations": {
    "*.html": "html"
  },

  // Tailwind CSSのIntelliSense設定
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "rust": "html"
  },

  // CSS/JSONファイルはPrettierでフォーマット
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
